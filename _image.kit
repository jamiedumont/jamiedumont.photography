<a style="flex: <!-- @aspect_ratio -->;" class="gallery-image"
data-pswp-width="2560" 
data-pswp-height="<!-- @height -->"
href="<!-- @base_path -->/2560w/<!-- @file_name -->.jpg"
target="_blank">
    <picture>
      <source srcset="<!-- @base_path -->/640w/<!-- @file_name -->.webp 640w, <!-- @base_path -->/1280w/<!-- @file_name -->.webp 1280w, <!-- @base_path -->/2560w/<!-- @file_name -->.webp 2560w" type="image/webp">
      <img srcset="<!-- @base_path -->/640w/<!-- @file_name -->.jpg 640w, <!-- @base_path -->/1280w/<!-- @file_name -->.jpg 1280w, <!-- @base_path -->/2560w/<!-- @file_name -->.jpg 2560w" src="<!-- @base_path -->/1280w/<!-- @file_name -->.jpg" alt="<!-- @alt -->" loading="lazy" decoding="async">
    </picture>
</a>